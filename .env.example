# ===========================================
# Suara Nabawiy — Environment Variables
# ===========================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/suara_nabawiy

# Radio Streaming
STREAM_URL=https://your-stream-url.com/stream
NEXT_PUBLIC_STREAM_URL=https://your-stream-url.com/stream

# API
API_PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:3002

# Storage (Cloudflare R2 / AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=suara-nabawiy-storage

# Payment Gateway (Midtrans)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# App
NODE_ENV=development
