{
  "version": 2,
  "buildCommand": "echo 'skip'",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "packages/api/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "packages/api/api/index.ts"
    },
    {
      "src": "/api/v1",
      "dest": "packages/api/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "packages/api/api/index.ts"
    }
  ]
}
